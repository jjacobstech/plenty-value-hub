# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_NAME='Plenty Value'
VITE_APP_NAME='Plenty Value'
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie
MAIL_MAILER=smtp
MAIL_FROM_NAME=Your name
MAIL_FROM_ADDRESS=app@yourdomain.com
SMTP_HOST=localhost
SMTP_PORT=1025

# OAuth - Google
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Database
DB_CONNECTION=pg
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=plenty_value_hub

# Object Storage (SeaweedFS — S3-compatible, path-style)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=plenty-value-hub
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:8333