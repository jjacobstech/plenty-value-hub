{
  "name": "NewsletterSubscriber",
  "type": "object",
  "properties": {
    "email": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "unsubscribed"
      ],
      "default": "active"
    },
    "source": {
      "type": "string"
    }
  },
  "required": [
    "email"
  ]
}